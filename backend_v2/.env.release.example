APP_IMAGE=ghcr.io/qingshuishui/kcb-backend-v2
APP_TAG=backend-v0.1.1

APP_ENV=production
API_PORT=8000

POSTGRES_DB=kcb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-me
DEPLOY_BASE_PATH=/opt/huekcb/releases

DATABASE_URL=postgresql+psycopg://postgres:replace-me@postgres:5432/kcb
REDIS_URL=redis://redis:6379/0

JWT_SECRET=replace-me
CREDENTIAL_ENCRYPTION_KEY=replace-me
SENTRY_DSN=
